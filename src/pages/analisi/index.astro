---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchPublishedSlugs } from '../../lib/lab-stats.js';

const analisiModules = import.meta.glob('/analisi/*/README.md', { eager: true });
const publishedSlugs = await fetchPublishedSlugs();

interface AnalisiMeta {
  slug: string;
  title: string;
  excerpt: string;
  topics: string[];
  status: string;
  datasetSlug: string | null;
  isPublished: boolean;
}

const analisiList: AnalisiMeta[] = Object.entries(analisiModules)
  .filter(([filepath]) => !filepath.includes('/_template/') && !filepath.includes('/registry/'))
  .map(([filepath, mod]: [string, any]) => {
    const parts = filepath.split('/');
    const slug = parts[parts.length - 2] ?? '';
    const fm = mod.frontmatter ?? {};
    const datasetSlug = fm.dataset_slug || null;
    return {
      slug,
      title: fm.title || slug,
      excerpt: fm.description || '',
      topics: fm.topics ? fm.topics.split(',').map((t: string) => t.trim()) : [],
      status: fm.status || 'active',
      datasetSlug,
      isPublished: datasetSlug ? publishedSlugs.has(datasetSlug) : false,
    };
  })
  .sort((a, b) => a.slug.localeCompare(b.slug));
---

<BaseLayout title="Analisi" description="Lavori in corso e finding pubblici del DataCivicLab">
  <p class="section-sub">
    Ogni filone parte da una domanda civica e arriva a un'analisi pubblica con notebook e dati.
  </p>

  {analisiList.length === 0 && <p><em>Nessuna analisi ancora pubblicata.</em></p>}

  {analisiList.map((entry) => (
    <div class="card">
      <h2><a href={`${import.meta.env.BASE_URL}analisi/${entry.slug}/`}>{entry.title}</a></h2>
      {entry.excerpt && <p>{entry.excerpt}</p>}
      <div class="analisi-meta">
        {entry.topics.length > 0
          ? entry.topics.map((topic) => (
              <span class={`topic-badge topic-${topic}`}>
                {topic}
              </span>
            ))
          : <span class="topic-badge muted">generale</span>
        }
        <span class={`topic-badge status-${entry.status}`}>
          {entry.status}
        </span>
        {entry.isPublished && (
          <a href="https://dataciviclab.github.io/data-explorer/" class="explorer-badge">
            📚 Su Explorer
          </a>
        )}
      </div>
    </div>
  ))}
</BaseLayout>

<style>
  .analisi-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .topic-badge {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 500;
    color: #fff;
    background: #64748b;
  }

  .topic-badge.muted {
    background: var(--bg-muted);
    color: var(--text-tertiary);
    border: 1px solid var(--border);
  }

  .topic-economia,
  .topic-fisco { background: #065f46; }

  .topic-pubblica-amministrazione { background: #6d28d9; }
  .topic-giustizia { background: #b91c1c; }
  .topic-sanita { background: #0e7490; }
  .topic-energia { background: #d97706; }
  .topic-ambiente { background: #15803d; }
  .topic-enti-locali { background: #4338ca; }

  .status-active { background: #16a34a; }
  .status-archived { background: #94a3b8; }
  .status-review { background: #d97706; }

  .explorer-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    background: var(--accent-light);
    color: var(--accent);
    text-decoration: none;
    transition: all 0.15s;
  }

  .explorer-badge:hover {
    background: var(--accent);
    color: #fff;
    text-decoration: none;
  }
</style>
